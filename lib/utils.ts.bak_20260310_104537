export const CROP_ICON_MAP: Record<string, string> = {
  "딸기": "🍓",
  "고구마": "🍠",
  "감자": "🥔",
  "샤인머스캣": "🍇",
  "고구마 라떼": "🧋",
  "샤인머스캣 주스": "🍷",
  "딸기잼": "🫙",
  "딸기주스": "🍹",
};

const pad = (n: number) => String(n).padStart(2, "0");

export function toKSTDate(date: Date | string | number = new Date()): Date {
  const d = new Date(date);
  return new Date(d.getTime() + 9 * 60 * 60 * 1000);
}

export function getNowKST(): Date {
  return toKSTDate(new Date());
}

export function formatKSTDate(
  date: Date | string | number = new Date(),
  format = "YYYY-MM-DD HH:mm:ss"
): string {
  const d = toKSTDate(date);
  const YYYY = d.getUTCFullYear();
  const MM = pad(d.getUTCMonth() + 1);
  const DD = pad(d.getUTCDate());
  const HH = pad(d.getUTCHours());
  const mm = pad(d.getUTCMinutes());
  const ss = pad(d.getUTCSeconds());

  if (format === "YYYY-MM-DD") return `${YYYY}-${MM}-${DD}`;
  return `${YYYY}-${MM}-${DD} ${HH}:${mm}:${ss}`;
}

export function toKSTDateString(date: Date | string | number = new Date()): string {
  return formatKSTDate(date, "YYYY-MM-DD");
}

export function formatKSTLocale(date: Date | string | number = new Date()): string {
  const d = new Date(date);
  return d.toLocaleString("ko-KR", { timeZone: "Asia/Seoul" });
}

export function generateId(): string {
  if (typeof crypto !== "undefined" && typeof crypto.randomUUID === "function") {
    return crypto.randomUUID();
  }
  return `${Date.now()}-${Math.random().toString(36).slice(2, 10)}`;
}

export function stripNonDigits(value: string): string {
  return String(value ?? "").replace(/\D/g, "");
}

export function getCropIcon(cropName?: string | null, fallback = "🌱"): string {
  if (!cropName) return fallback;
  return CROP_ICON_MAP[cropName] ?? fallback;
}
